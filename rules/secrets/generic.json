[
  {
    "id": "SEC001",
    "title": "AWS Access Key",
    "severity": "critical",
    "extensions": [],
    "pattern": "AKIA[0-9A-Z]{16}",
    "description": "Credencial AWS hardcodeada"
  },
  {
    "id": "SEC002",
    "title": "API key o token genérico",
    "severity": "high",
    "extensions": [],
    "pattern": "(?i)(api_key|api_token|access_token|auth_token)\\s*=\\s*['\"][a-zA-Z0-9_\\-]{16,}['\"]",
    "description": "Token asignado directamente en código"
  },
  {
    "id": "SEC003",
    "title": "Password hardcodeado",
    "severity": "high",
    "extensions": [],
    "pattern": "(?i)(password|passwd|pwd)\\s*=\\s*['\"][^'\"]{4,}['\"]",
    "description": "Contraseña en texto plano"
  },
  {
    "id": "SEC004",
    "title": "Clave privada embebida",
    "severity": "critical",
    "extensions": [],
    "pattern": "-----BEGIN (RSA|EC|OPENSSH) PRIVATE KEY-----",
    "description": "Clave privada en el repositorio"
  },
  {
    "id": "SEC005",
    "title": "URI de BD con credenciales",
    "severity": "high",
    "extensions": [],
    "pattern": "(?i)(postgres|mysql|mongodb|redis)://[^:]+:[^@]+@",
    "description": "Cadena de conexión con usuario y contraseña expuestos"
  },
  {
    "id": "SEC006",
    "title": "GitHub token",
    "severity": "critical",
    "extensions": [],
    "pattern": "gh[pousr]_[A-Za-z0-9_]{36,}",
    "description": "Personal Access Token de GitHub expuesto"
  },
  {
    "id": "SEC007",
    "title": "Slack webhook URL",
    "severity": "high",
    "extensions": [],
    "pattern": "https://hooks\\.slack\\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]+",
    "description": "Webhook de Slack permite enviar mensajes sin autenticación"
  },
  {
    "id": "SEC008",
    "title": "Google API Key",
    "severity": "high",
    "extensions": [],
    "pattern": "AIza[0-9A-Za-z_\\-]{35}",
    "description": "Clave de API de Google expuesta"
  },
  {
    "id": "SEC009",
    "title": "JWT secret hardcodeado",
    "severity": "high",
    "extensions": [],
    "pattern": "(?i)jwt[_\\-]?(secret|key)\\s*=\\s*['\"][^'\"]{8,}['\"]",
    "description": "Secreto JWT en texto plano compromete todos los tokens"
  },
  {
    "id": "SEC010",
    "title": "SendGrid API Key",
    "severity": "high",
    "extensions": [],
    "pattern": "SG\\.[a-zA-Z0-9_\\-]{22}\\.[a-zA-Z0-9_\\-]{43}",
    "description": "Clave de SendGrid expuesta — permite envío de correos"
  },
  {
    "id": "SEC011",
    "title": "Stripe Secret Key",
    "severity": "critical",
    "extensions": [],
    "pattern": "(?i)sk_live_[0-9a-zA-Z]{24,}",
    "description": "Clave secreta de Stripe expuesta — riesgo financiero crítico"
  },
  {
    "id": "SEC012",
    "title": "Twilio API Key",
    "severity": "high",
    "extensions": [],
    "pattern": "SK[0-9a-fA-F]{32}",
    "description": "Clave de la API de Twilio expuesta en código"
  },
  {
    "id": "SEC013",
    "title": "Mailgun API Key",
    "severity": "high",
    "extensions": [],
    "pattern": "key-[0-9a-zA-Z]{32}",
    "description": "Clave de API de Mailgun expuesta — permite envío de correos no autorizados"
  },
  {
    "id": "SEC014",
    "title": "PGP Private Key",
    "severity": "critical",
    "extensions": [],
    "pattern": "-----BEGIN PGP PRIVATE KEY BLOCK-----",
    "description": "Bloque de clave privada PGP embebido en el código"
  },
  {
    "id": "SEC015",
    "title": "Credenciales Basic Auth en URL",
    "severity": "high",
    "extensions": [],
    "pattern": "https?://[a-zA-Z0-9%_-]+:[a-zA-Z0-9%_-]+@[a-zA-Z0-9.-]+",
    "description": "Credenciales en texto plano incrustadas dentro de una URL"
  },
  {
    "id": "SEC016",
    "title": "RSA/DSA Public Key",
    "severity": "low",
    "extensions": [],
    "pattern": "-----BEGIN PUBLIC KEY-----",
    "description": "Clave pública en el código (informacional, pero valioso para auditorías)"
  }
]